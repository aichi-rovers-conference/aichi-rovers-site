{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      { "name": "next" }
    ],

    /* ★ ここを重要修正 */
    "baseUrl": ".",
    "paths": {
      "@/*": ["*"]                /* app/ も src/ も含めてプロジェクト直下を解決 */
      /* もし厳密に分けたい場合は下記でもOK:
         "@/*": ["./app/*", "./src/*"]
      */
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
