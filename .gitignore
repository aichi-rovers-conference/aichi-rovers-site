# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# --- Prisma のローカル SQLite を誤コミットしない ---
prisma/*.db
prisma/*.db-journal

# --- アップロード先（リポジトリには載せない）---
public/uploads/*
!public/uploads/.gitkeep   # 空ディレクトリ保持用

# --- OS / 開発ツール（任意）---
Thumbs.db
.eslintcache
# .idea/       # JetBrains を使っていれば有効化
# .vscode/     # ワークスペース設定を共有しないなら有効化
